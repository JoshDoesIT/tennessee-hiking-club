# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Capacitor native projects are committed (they carry native customizations:
# the tnhc:// sign-in deep link, background-location permissions, splash). Build
# outputs and machine-specific files are excluded by ios/.gitignore and
# android/.gitignore. Regenerated source (web assets, synced config) below.
/ios/App/App/public
/android/app/src/main/assets/public
/ios/App/App/capacitor.config.json
/android/app/src/main/assets/capacitor.config.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the committed template documents what each variable does.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
