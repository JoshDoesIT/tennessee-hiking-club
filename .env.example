# Tennessee Hiking Club: environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in the values you need.
# Almost everything here is optional: the app runs local-first with no env at
# all, and each feature below stays off until its variables are set. Names match
# what the code reads; see the cited files for details.

# --- Database (Neon Postgres) ---------------------------------------------
# Pooled connection string, used at runtime. Without it the account features
# (sign-in, cross-device sync, passkeys) are disabled and the app stays purely
# local-first.
DATABASE_URL=
# Direct (unpooled) connection, used by drizzle-kit for migrations. Falls back
# to DATABASE_URL if unset (drizzle.config.ts).
DATABASE_URL_UNPOOLED=

# --- Auth.js / NextAuth v5 ------------------------------------------------
# Required in production: a random secret for signing tokens. Generate one with
# `npx auth secret`.
AUTH_SECRET=
# Sign-in providers. Each provider is added only when its `_ID` is present
# (src/lib/auth/config.ts), so you can enable just the ones you want.
# GitHub OAuth app: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google OAuth client: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Facebook (Meta) app: https://developers.facebook.com/apps/create/ (see #234).
# Redirect URI: https://www.tnhiking.club/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
# Facebook stays off even with the credentials above until this is "true": its
# login only works for app admins until Meta business verification is done
# (#234). Set to "true" to show the Facebook button once verified.
AUTH_FACEBOOK_ENABLED=
# Comma-separated GitHub logins granted admin access (src/lib/auth/is-admin.ts).
ADMIN_GITHUB_LOGINS=

# --- Blob storage (Vercel Blob) -------------------------------------------
# Stores uploaded hike and trail-contribution photos. Without it, photo uploads
# are rejected with a clear message (src/app/api/hikes/photo/route.ts).
BLOB_READ_WRITE_TOKEN=

# --- Trail content pull requests (optional) -------------------------------
# Lets trail submissions open a PR against the content repo. Repo and base
# branch default to the project's own (src/lib/github/content-pr.ts); the token
# needs `repo` scope.
GITHUB_CONTENT_REPO=
GITHUB_CONTENT_BASE=
GITHUB_CONTENT_TOKEN=

# --- Store / merch (optional) ---------------------------------------------
# Stripe checkout + webhook, and Printful for fulfilment.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRINTFUL_API_KEY=

# --- Capacitor mobile shell (optional) ------------------------------------
# Overrides the origin the native app loads; defaults to the production site
# (capacitor.config.ts). Set to a preview deploy or your LAN dev URL to test.
CAP_SERVER_URL=
